{
  "name": "getdevflow/custom-fields",
  "description": "A powerful and flexible developer-friendly custom fields plugin for Devflow CMF.",
  "type": "devflow-plugin",
  "keywords": ["customfields","custom-fields","metadata","usermeta","user-meta"],
  "license": "GPL-2.0-only",
  "authors": [
    {
      "name": "Joshua Parker",
      "email": "joshua@joshuaparker.dev"
    }
  ],
  "require": {
    "php": ">=8.4",
    "oomphinc/composer-installers-extender": "^2.0"
  },
  "extra": {
    "installer-name": "CustomFields",
    "installer-types": ["devflow-plugin"]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "oomphinc/composer-installers-extender": true
    }
  }
}
