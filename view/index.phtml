<script>
    jQuery(function ($) {
        function updateAllCheckboxes(state) {
            $('.cf-row-check').prop('checked', state);
            $('#cf-check-all').prop('checked', state);
            $('#cf-check-all-footer').prop('checked', state);
        }

        $('#cf-check-all, #cf-check-all-footer').on('change', function () {
            updateAllCheckboxes($(this).is(':checked'));
        });

        $('.cf-row-check').on('change', function () {
            const total = $('.cf-row-check').length;
            const checked = $('.cf-row-check:checked').length;

            const allChecked = total > 0 && total === checked;

            $('#cf-check-all').prop('checked', allChecked);
            $('#cf-check-all-footer').prop('checked', allChecked);
        });

        $('#custom-fields-bulk-form').on('submit', function (e) {
            const $form = $(this);

            if ($form.data('confirmed') === true) {
                return;
            }

            const action = $('[name="bulk_action"]').val();
            const selected = $('.cf-row-check:checked').length;
            const $modal = $('#cf-bulk-delete-modal');

            if (!action) {
                e.preventDefault();

                alert('Please choose a bulk action.');

                return;
            }

            if (selected === 0) {
                e.preventDefault();

                alert('Please select at least one field group.');

                return;
            }

            if (action === 'delete') {
                e.preventDefault();
                $modal
                    .css('z-index', 210000)
                    .modal({
                        backdrop: true,
                        keyboard: true,
                        show: true
                    });

                setTimeout(function () {
                    $('.modal-backdrop')
                        .last()
                        .addClass('cf-bulk-delete-backdrop')
                        .css('z-index', 209990);

                    $modal.find('[data-dismiss="modal"], .btn-danger, .btn-default').first().focus();
                }, 10);
                return;
            }
        });

        let cfPendingBulkSubmit = false;

        $('#cf-confirm-bulk-delete').on('click', function () {
            if (cfPendingBulkSubmit) {
                return;
            }

            cfPendingBulkSubmit = true;

            $('#cf-bulk-delete-modal').modal('hide');

            $('#custom-fields-bulk-form')
                .data('confirmed', true)
                .trigger('submit');
        });

        $(document).on('keydown', function (event) {
            if (event.key === 'Escape' && $('#cf-bulk-delete-modal').is(':visible')) {
                $('#cf-bulk-delete-modal').modal('hide');
            }
        });
    });
</script>

